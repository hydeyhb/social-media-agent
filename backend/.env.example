# ─── OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Facebook (Meta Developer App) ───────────────────────
# Create app at: https://developers.facebook.com/apps/
FACEBOOK_APP_ID=your_app_id
FACEBOOK_APP_SECRET=your_app_secret
# For production, replace with your Railway URL:
#   https://your-app.up.railway.app/api/auth/facebook/callback
FACEBOOK_REDIRECT_URI=http://localhost:8000/api/auth/facebook/callback

# Required FB App Permissions:
#   pages_manage_posts, pages_read_engagement,
#   pages_show_list, pages_read_user_content

# ─── Threads (Meta Developer App) ────────────────────────
# Use the same Meta App; enable Threads API product
THREADS_APP_ID=your_app_id
THREADS_APP_SECRET=your_app_secret
# For production, replace with your Railway URL:
#   https://your-app.up.railway.app/api/auth/threads/callback
THREADS_REDIRECT_URI=http://localhost:8000/api/auth/threads/callback

# Required Threads Permissions:
#   threads_basic, threads_content_publish,
#   threads_manage_replies, threads_read_engagement

# ─── Security ─────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=your_fernet_key_here

SECRET_KEY=change_me_to_a_random_string

# ─── Admin Auth ──────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
JWT_EXPIRATION_MINUTES=480

# ─── App ──────────────────────────────────────────────────
DATABASE_URL=sqlite:///./social_agent.db
UPLOADS_DIR=./uploads
# For production, set to your Railway URL:
#   https://your-app.up.railway.app
FRONTEND_URL=http://localhost:5173

# ─── Webhooks ─────────────────────────────────────────────
# Set this same value in Meta Developer Console → Webhook Verify Token
FACEBOOK_WEBHOOK_VERIFY_TOKEN=my_webhook_verify_token
